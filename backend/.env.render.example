# Example Environment Configuration for Render Deployment

# DATABASE - REQUIRED
# Format: postgresql+asyncpg://username:password@host:port/database
# For Render PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://simba_user:your_password@dpg-xxxxx.oregon-postgres.render.com:5432/simba_db

DATABASE_URL=

# APPLICATION
DEBUG=false
FRONTEND_URL=https://your-frontend-domain.vercel.app

# AUTHENTICATION - REQUIRED
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# FIREBASE - REQUIRED
FIREBASE_PROJECT_ID=your-firebase-project-id
# This should be the full JSON content on one line (or you can use structured form in Render)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# ADMIN USER (initial setup)
ADMIN_USER_ID=your-admin-firebase-uid
ADMIN_USER_EMAIL=admin@example.com

# PAYMENT - REQUIRED for checkout
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# AI SERVICES - OPTIONAL
GROQ_API_KEY=gsk_your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
APP_AI_BASE_URL=
APP_AI_KEY=

# OBJECT STORAGE - OPTIONAL
OSS_SERVICE_URL=
OSS_API_KEY=

# AWS LAMBDA - Set to false for Render
IS_LAMBDA=false
AWS_REGION=us-east-1

# RENDER SPECIFIC
# Set PORT for Render if needed (Render automatically detects this)
# PORT=8000
