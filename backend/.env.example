# ==========================================
# Backend Environment Configuration Example
# ==========================================
# IMPORTANT: Never commit .env with real values!
# Copy this file to .env and fill in your actual values.

# ===================
# Application Settings
# ===================
DEBUG=true
ENVIRONMENT=dev
HOST=127.0.0.1
PORT=8000

# ===================
# Database (CRITICAL)
# ===================
# Format: postgresql+asyncpg://username:password@hostname:port/dbname
# 
# LOCAL DEVELOPMENT:
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/simba_db
#
# RENDER.COM DEPLOYMENT:
# Get connection string from Render PostgreSQL dashboard (Internal Database URL)
# Example: postgresql+asyncpg://user:pass@dpg-xxxxx.oregon-postgres.render.com:5432/simba_db
#
# NEON (Serverless PostgreSQL):
# Example: postgresql+asyncpg://neondb_owner:password@ep-xxxxx.us-east-1.postgres.vercel-storage.com/neondb
#
# SUPABASE:
# Example: postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
# DO NOT USE THE ANON/SERVICE ROLE KEYS - these are API credentials, not database URLs
DATABASE_URL=postgresql+asyncpg://username:password@hostname:5432/database_name

# ==================
# JWT Configuration
# ==================
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ==================
# Frontend URL
# ==================
# For CORS configuration - update based on deployment environment
FRONTEND_URL=http://localhost:3000

# ==================
# Firebase Configuration
# ==================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=path/to/firebase-adminsdk.json

# Optional: Admin user for initialization
ADMIN_USER_ID=optional-admin-user-id
ADMIN_USER_EMAIL=admin@example.com

# ==================
# AI/ML Services
# ==================
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# ==================
# Feature Flags
# ==================
MGX_IGNORE_INIT_ADMIN=1
